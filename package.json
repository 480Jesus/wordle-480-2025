{
  "name": "wordle-typescript",
  "version": "1.0.0",
  "description": "A wordle game clone",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node build/app.js",
    "dev": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm src/app.ts\"",
    "tsc": "tsc",
    "test": "jest --passWithNoTests",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XarxatecJano/wordle-typescript.git"
  },
  "keywords": [
    "wordle",
    "typescript",
    "nodejs",
    "express"
  ],
  "author": "Jano Soler",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/XarxatecJano/wordle-typescript/issues"
  },
  "homepage": "https://github.com/XarxatecJano/wordle-typescript#readme",
  "dependencies": {
    "@types/express": "^4.17.13",
    "express": "^4.18.2",
    "nodemon": "^2.0.15"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.17.2",
    "jest": "^29.7.0",
    "nodemon": "^2.0.15",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.0.0"
  }
}
