{
 "compilerOptions": {
 "target": "ES2020",
 "module": "ES2020",
 "moduleResolution": "node",
 "rootDir": "./src",
 "outDir": "./build",
 "lib": ["ES2020", "DOM"],
 "esModuleInterop": true,
 "forceConsistentCasingInFileNames": true,
 "strict": true,
 "skipLibCheck": true
 },
 "include": ["src/**/*.ts"]
}